# =========================
# SmaTelcom — Git Ignore
# Local-first AI Orchestrator for Telco Networks
# =========================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build / Dist ---
dist/
dist-ssr/
build/
out/
*.local

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
cargo-*.log

# --- Environment / Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
Desktop.ini

# --- Rust / Tauri ---
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/WixTools/
src-tauri/*.exe
**/*.rs.bk
Cargo.lock.bak

# --- Test / Coverage ---
coverage/
*.lcov
.nyc_output/

# --- Caches ---
.cache/
.turbo/
.parcel-cache/
*.tsbuildinfo
.eslintcache

# --- Ollama / Local model artifacts (never commit) ---
models/
*.gguf
*.bin
ollama/

# --- Runtime / Simulation data ---
data/runtime/
data/telemetry/*.jsonl
!data/telemetry/.gitkeep
tmp/
temp/

# --- Knowledge base uploads (keep seed manuals, ignore user dumps) ---
knowledge_base/private/
knowledge_base/uploads/
*.pdf.bak

# --- Package manager locks (optional — keep package-lock.json tracked) ---
# yarn.lock
# pnpm-lock.yaml

# --- Misc ---
*.bak
*.tmp
*.temp
.history/
